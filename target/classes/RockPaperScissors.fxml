<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="RPSController"
      prefHeight="600.0" prefWidth="454.0">

   <!-- Menu Bar -->
   <MenuBar>
      <menus>
         <Menu text="Game">
            <items>
               <MenuItem text="New Game" onAction="#onNewGame"/>
               <MenuItem text="Exit" onAction="#onExit"/>
            </items>
         </Menu>
         <Menu text="Help">
            <items>
               <MenuItem text="About" onAction="#onAbout"/>
            </items>
         </Menu>
      </menus>
   </MenuBar>

   <Pane prefHeight="552.0" prefWidth="454.0">
      <children>

         <!-- Round display -->
         <Text fx:id="roundLabel" layoutX="163.0" layoutY="56.0"
               strokeType="OUTSIDE" strokeWidth="0.0" text="Round: 0">
            <font><Font size="30.0"/></font>
         </Text>

         <!-- Human section -->
         <Text layoutX="193.0" layoutY="100.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Human">
            <font><Font size="20.0"/></font>
         </Text>

         <!-- Rock Paper Scissors buttons -->
         <ButtonBar buttonOrder="" layoutX="95.0" layoutY="115.0"
                    prefHeight="40.0" prefWidth="260.0">
            <buttons>
               <Button mnemonicParsing="false" text="Rock" onAction="#onRock"/>
               <Button mnemonicParsing="false" text="Paper" onAction="#onPaper"/>
               <Button mnemonicParsing="false" text="Scissors" onAction="#onScissors"/>
            </buttons>
            <padding><Insets right="10.0"/></padding>
         </ButtonBar>

         <!-- Human choice display -->
         <Text fx:id="humanChoiceLabel" layoutX="119.0" layoutY="175.0"
               strokeType="OUTSIDE" strokeWidth="0.0" text="Human Chooses: "/>

         <!-- Computer section -->
         <Pane layoutY="210.0" prefHeight="180.0" prefWidth="454.0">
            <children>
               <Text layoutX="183.0" layoutY="22.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Computer">
                  <font><Font size="20.0"/></font>
               </Text>
               <Text fx:id="predictedLabel" layoutX="76.0" layoutY="60.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Predicted Human Choice: "/>
               <Text fx:id="computerChoiceLabel" layoutX="76.0" layoutY="85.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Computer Chooses: "/>
               <Text fx:id="winnerLabel" layoutX="139.0" layoutY="130.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Winner: ">
                  <font><Font size="24.0"/></font>
               </Text>
            </children>
         </Pane>

         <!-- Stats section -->
         <Pane layoutY="400.0" prefHeight="163.0" prefWidth="454.0">
            <children>
               <Text layoutX="185.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Statistics">
                  <font><Font size="18.0"/></font>
               </Text>
               <Text fx:id="humanWinsLabel" layoutX="136.0" layoutY="60.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Human Wins: 0"/>
               <Text fx:id="computerWinsLabel" layoutX="121.0" layoutY="80.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Computer Wins: 0"/>
               <Text fx:id="tiesLabel" layoutX="187.0" layoutY="100.0"
                     strokeType="OUTSIDE" strokeWidth="0.0" text="Ties: 0"/>
            </children>
         </Pane>

      </children>
   </Pane>
</VBox>